# Save exact versions instead of using ranges
save-exact=true

# Use npm audit to automatically fix vulnerabilities when installing
audit-level=moderate

# Set the default registry (can be overridden for specific scopes)
registry=https://registry.npmjs.org/

# Progress indicator for package installation
progress=true

# Log level for npm operations
loglevel=warn

# Use package-lock.json and respect existing lockfile
package-lock=true

# Don't automatically save dependencies to package.json
save=false

# Disable funding messages
fund=false

# Engine strict - fail if Node/npm version doesn't match engines field
engine-strict=false

# Optional: Set cache directory (uncomment if needed)
# cache=/path/to/npm/cache

# Optional: Set prefix for global packages (uncomment if needed)
# prefix=/usr/local
