{
  "defaults": {
    "standard": "WCAG2AA",
    "timeout": 30000,
    "wait": 1000,
    "viewport": {
      "width": 1280,
      "height": 1024
    },
    "runners": [
      "axe",
      "htmlcs"
    ],
    "hideElements": ".visually-hidden",
    "ignore": [],
    "includeNotices": false,
    "includeWarnings": true,
    "threshold": 0,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    }
  },
  "urls": [
    "http://localhost:5173"
  ]
}